generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenantRole {
  OWNER
  ADMIN
  MODERATOR
  USER

  @@map("tenant_role")
}

enum PlatformRole {
  PLATFORM_ADMIN
  NONE

  @@map("platform_role")
}

enum GuildStatus {
  ACTIVE
  DISABLED
  LEFT

  @@map("guild_status")
}

enum MemberStatus {
  ACTIVE
  INVITED
  REMOVED

  @@map("member_status")
}

enum JobStatus {
  QUEUED
  RUNNING
  FAILED
  COMPLETED
  CANCELLED

  @@map("job_status")
}

enum AuditActorType {
  USER
  SYSTEM
  PLATFORM_ADMIN

  @@map("audit_actor_type")
}

enum LlmConversationType {
  GUILD_CHANNEL
  DM

  @@map("llm_conversation_type")
}

enum LlmMessageRole {
  SYSTEM
  USER
  ASSISTANT

  @@map("llm_message_role")
}

enum LlmGenerationStatus {
  SUCCESS
  FAILED
  SKIPPED

  @@map("llm_generation_status")
}

model Guild {
  id                 String              @id(map: "pk_guilds") @db.Uuid
  discordGuildId     String              @unique(map: "ux_guilds_discord_guild_id") @map("discord_guild_id")
  name               String
  status             GuildStatus         @default(ACTIVE)
  ownerDiscordUserId String?             @map("owner_discord_user_id")
  createdAt          DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime            @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  members            GuildMember[]
  featureFlags       FeatureFlag[]
  commandPermissions CommandPermission[]
  auditLogs          AuditLog[]
  jobRuns            JobRun[]
  webhookDeliveries  WebhookDelivery[]
  llmSetting         LlmGuildSetting?
  llmChannelSettings LlmChannelSetting[]
  llmConversations   LlmConversation[]
  llmGenerations     LlmGeneration[]
  llmModerationEvents LlmModerationEvent[]

  @@index([status], map: "ix_guilds_status")
  @@map("guilds")
}

model User {
  id            String         @id(map: "pk_users") @db.Uuid
  discordUserId String         @unique(map: "ux_users_discord_user_id") @map("discord_user_id")
  username      String?
  globalName    String?        @map("global_name")
  avatarUrl     String?        @map("avatar_url")
  platformRole  PlatformRole   @default(NONE) @map("platform_role")
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  memberships   GuildMember[]
  auditLogs     AuditLog[]
  oauthSessions OauthSession[]

  @@map("users")
}

model GuildMember {
  guildId    String      @map("guild_id") @db.Uuid
  userId     String      @map("user_id") @db.Uuid
  tenantRole TenantRole  @default(USER) @map("tenant_role")
  status     MemberStatus @default(ACTIVE)
  joinedAt   DateTime?   @map("joined_at") @db.Timestamptz(6)
  lastSeenAt DateTime?   @map("last_seen_at") @db.Timestamptz(6)
  createdAt  DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  guild      Guild       @relation(fields: [guildId], references: [id], onDelete: Cascade, map: "fk_guild_members_guilds")
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade, map: "fk_guild_members_users")

  @@id([guildId, userId], map: "pk_guild_members")
  @@index([userId], map: "ix_guild_members_user_id")
  @@index([guildId, tenantRole], map: "ix_guild_members_guild_role")
  @@map("guild_members")
}

model FeatureFlag {
  id         String   @id(map: "pk_feature_flags") @db.Uuid
  guildId    String   @map("guild_id") @db.Uuid
  featureKey String   @map("feature_key")
  enabled    Boolean  @default(false)
  configJson Json     @default("{}") @map("config_json")
  version    Int      @default(1)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  guild      Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade, map: "fk_feature_flags_guilds")

  @@unique([guildId, featureKey], map: "ux_feature_flags_guild_feature_key")
  @@index([guildId], map: "ix_feature_flags_guild_id")
  @@index([guildId, enabled], map: "ix_feature_flags_guild_enabled")
  @@map("feature_flags")
}

model CommandPermission {
  id               String     @id(map: "pk_command_permissions") @db.Uuid
  guildId          String     @map("guild_id") @db.Uuid
  commandKey       String     @map("command_key")
  minRole          TenantRole @default(MODERATOR) @map("min_role")
  allowChannelsJson Json      @default("[]") @map("allow_channels_json")
  denyChannelsJson  Json      @default("[]") @map("deny_channels_json")
  createdAt        DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  guild            Guild      @relation(fields: [guildId], references: [id], onDelete: Cascade, map: "fk_command_permissions_guilds")

  @@unique([guildId, commandKey], map: "ux_command_permissions_guild_command_key")
  @@index([guildId], map: "ix_command_permissions_guild_id")
  @@map("command_permissions")
}

model AuditLog {
  id          String         @id(map: "pk_audit_logs") @db.Uuid
  guildId     String         @map("guild_id") @db.Uuid
  actorUserId String?        @map("actor_user_id") @db.Uuid
  actorType   AuditActorType @map("actor_type")
  action      String
  entityType  String         @map("entity_type")
  entityId    String         @map("entity_id")
  beforeJson  Json?          @map("before_json")
  afterJson   Json?          @map("after_json")
  metadataJson Json          @default("{}") @map("metadata_json")
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  guild       Guild          @relation(fields: [guildId], references: [id], onDelete: Restrict, map: "fk_audit_logs_guilds")
  actorUser   User?          @relation(fields: [actorUserId], references: [id], onDelete: SetNull, map: "fk_audit_logs_users")

  @@index([guildId, createdAt(sort: Desc)], map: "ix_audit_logs_guild_created")
  @@index([guildId, action, createdAt(sort: Desc)], map: "ix_audit_logs_guild_action")
  @@index([actorUserId, createdAt(sort: Desc)], map: "ix_audit_logs_actor")
  @@map("audit_logs")
}

model JobRun {
  id          String    @id(map: "pk_job_runs") @db.Uuid
  guildId     String    @map("guild_id") @db.Uuid
  jobType     String    @map("job_type")
  status      JobStatus @default(QUEUED)
  attempts    Int       @default(0)
  maxAttempts Int       @default(10) @map("max_attempts")
  payloadJson Json      @default("{}") @map("payload_json")
  resultJson  Json?     @map("result_json")
  errorText   String?   @map("error_text")
  scheduledAt DateTime  @default(now()) @map("scheduled_at") @db.Timestamptz(6)
  startedAt   DateTime? @map("started_at") @db.Timestamptz(6)
  finishedAt  DateTime? @map("finished_at") @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  guild       Guild     @relation(fields: [guildId], references: [id], onDelete: Restrict, map: "fk_job_runs_guilds")

  @@index([guildId, status, createdAt(sort: Desc)], map: "ix_job_runs_guild_status")
  @@index([status, scheduledAt], map: "ix_job_runs_schedule")
  @@map("job_runs")
}

model OauthSession {
  id               String   @id(map: "pk_oauth_sessions") @db.Uuid
  userId           String   @map("user_id") @db.Uuid
  sessionTokenHash String   @unique(map: "ux_oauth_sessions_session_token_hash") @map("session_token_hash")
  ipAddress        String?  @map("ip_address")
  userAgent        String?  @map("user_agent")
  expiresAt        DateTime @map("expires_at") @db.Timestamptz(6)
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade, map: "fk_oauth_sessions_users")

  @@index([userId], map: "ix_oauth_sessions_user_id")
  @@index([expiresAt], map: "ix_oauth_sessions_expires_at")
  @@map("oauth_sessions")
}

model WebhookDelivery {
  id          String   @id(map: "pk_webhook_deliveries") @db.Uuid
  guildId     String   @map("guild_id") @db.Uuid
  eventType   String   @map("event_type")
  targetUrl   String   @map("target_url")
  payloadJson Json     @map("payload_json")
  status      String
  attempts    Int      @default(0)
  lastError   String?  @map("last_error")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  guild       Guild    @relation(fields: [guildId], references: [id], onDelete: Restrict, map: "fk_webhook_deliveries_guilds")

  @@map("webhook_deliveries")
}

model LlmGuildSetting {
  id               String   @id(map: "pk_llm_guild_settings") @db.Uuid
  guildId          String   @unique(map: "ux_llm_guild_settings_guild_id") @map("guild_id") @db.Uuid
  enabled          Boolean  @default(false)
  defaultModel     String   @default("gpt-4.1-mini") @map("default_model")
  stylePrompt      String?  @map("style_prompt")
  retentionDays    Int      @default(90) @map("retention_days")
  dmEnabled        Boolean  @default(true) @map("dm_enabled")
  maxInputChars    Int      @default(4000) @map("max_input_chars")
  maxOutputTokens  Int      @default(512) @map("max_output_tokens")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  guild            Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade, map: "fk_llm_guild_settings_guilds")

  @@map("llm_guild_settings")
}

model LlmChannelSetting {
  id                   String   @id(map: "pk_llm_channel_settings") @db.Uuid
  guildId              String   @map("guild_id") @db.Uuid
  discordChannelId     String   @map("discord_channel_id")
  enabled              Boolean  @default(false)
  respondOnMentionOnly Boolean  @default(false) @map("respond_on_mention_only")
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  guild                Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade, map: "fk_llm_channel_settings_guilds")

  @@unique([guildId, discordChannelId], map: "ux_llm_channel_settings_guild_channel")
  @@index([guildId], map: "ix_llm_channel_settings_guild_id")
  @@map("llm_channel_settings")
}

model LlmConversation {
  id               String              @id(map: "pk_llm_conversations") @db.Uuid
  guildId          String?             @map("guild_id") @db.Uuid
  discordChannelId String?             @map("discord_channel_id")
  discordUserId    String?             @map("discord_user_id")
  type             LlmConversationType
  summaryText      String?             @map("summary_text")
  lastMessageAt    DateTime            @default(now()) @map("last_message_at") @db.Timestamptz(6)
  createdAt        DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime            @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  guild            Guild?              @relation(fields: [guildId], references: [id], onDelete: Cascade, map: "fk_llm_conversations_guilds")
  messages         LlmMessage[]
  generations      LlmGeneration[]
  moderationEvents LlmModerationEvent[]

  @@unique([guildId, discordChannelId, type], map: "ux_llm_conversations_guild_channel_type")
  @@unique([discordUserId, type], map: "ux_llm_conversations_user_type")
  @@index([guildId, lastMessageAt(sort: Desc)], map: "ix_llm_conversations_guild_last_message")
  @@index([discordUserId, lastMessageAt(sort: Desc)], map: "ix_llm_conversations_user_last_message")
  @@map("llm_conversations")
}

model LlmMessage {
  id             String         @id(map: "pk_llm_messages") @db.Uuid
  conversationId String         @map("conversation_id") @db.Uuid
  role           LlmMessageRole
  content        String
  tokenCount     Int?           @map("token_count")
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  conversation   LlmConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade, map: "fk_llm_messages_conversations")

  @@index([conversationId, createdAt(sort: Desc)], map: "ix_llm_messages_conversation_created")
  @@map("llm_messages")
}

model LlmGeneration {
  id             String              @id(map: "pk_llm_generations") @db.Uuid
  conversationId String              @map("conversation_id") @db.Uuid
  guildId        String?             @map("guild_id") @db.Uuid
  provider       String
  model          String
  status         LlmGenerationStatus @default(SUCCESS)
  inputTokens    Int                 @default(0) @map("input_tokens")
  outputTokens   Int                 @default(0) @map("output_tokens")
  latencyMs      Int                 @default(0) @map("latency_ms")
  errorCode      String?             @map("error_code")
  errorText      String?             @map("error_text")
  createdAt      DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  conversation   LlmConversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade, map: "fk_llm_generations_conversations")
  guild          Guild?              @relation(fields: [guildId], references: [id], onDelete: SetNull, map: "fk_llm_generations_guilds")

  @@index([guildId, createdAt(sort: Desc)], map: "ix_llm_generations_guild_created")
  @@index([conversationId, createdAt(sort: Desc)], map: "ix_llm_generations_conversation_created")
  @@map("llm_generations")
}

model LlmModerationEvent {
  id             String          @id(map: "pk_llm_moderation_events") @db.Uuid
  guildId        String?         @map("guild_id") @db.Uuid
  conversationId String?         @map("conversation_id") @db.Uuid
  category       String
  action         String
  detailsJson    Json            @default("{}") @map("details_json")
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  guild          Guild?          @relation(fields: [guildId], references: [id], onDelete: SetNull, map: "fk_llm_moderation_events_guilds")
  conversation   LlmConversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull, map: "fk_llm_moderation_events_conversations")

  @@index([guildId, createdAt(sort: Desc)], map: "ix_llm_moderation_events_guild_created")
  @@index([conversationId, createdAt(sort: Desc)], map: "ix_llm_moderation_events_conversation_created")
  @@map("llm_moderation_events")
}
